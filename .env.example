# Public API origin (no trailing slash). Used by Axios in the browser.
# Development: leave empty to call `/api/...` on the Vite dev server (proxied to Express).
# Production (Ubuntu CI/build): set to your public API URL, e.g. https://api.example.com
VITE_API_URL=

# Where the Vite dev server proxies `/api` (Node-only; not bundled). Default: http://127.0.0.1:3000
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
